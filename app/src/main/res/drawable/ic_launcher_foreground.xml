<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    
    <!-- Outer Cyan Cyber Crest Diamond -->
    <path
        android:pathData="M54,22 L86,54 L54,86 L22,54 Z"
        android:strokeWidth="3.5"
        android:strokeLineCap="round"
        android:strokeLineJoin="round">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="22"
                android:startY="54"
                android:endX="86"
                android:endY="54"
                android:type="linear">
                <item android:offset="0.0" android:color="#00F5FF" /> <!-- Cyan -->
                <item android:offset="1.0" android:color="#005CFF" /> <!-- Sapphire -->
            </gradient>
        </aapt:attr>
    </path>

    <!-- Inner Sapphire Accent Diamond -->
    <path
        android:pathData="M54,32 L76,54 L54,76 L32,54 Z"
        android:strokeWidth="1.5"
        android:strokeColor="#7F005CFF"
        android:strokeLineCap="round"
        android:strokeLineJoin="round" />

    <!-- Highly polished, glowing gradient central lightning/energy bolt of peak performance -->
    <path
        android:pathData="M42,68 L58,48 H48 L64,32 L48,52 H58 L42,68 Z"
        android:strokeWidth="0.5"
        android:strokeColor="#5000F5FF"
        android:strokeLineJoin="round">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="42"
                android:startY="68"
                android:endX="64"
                android:endY="32"
                android:type="linear">
                <item android:offset="0.0" android:color="#005CFF" /> <!-- Vibrant Blue -->
                <item android:offset="0.6" android:color="#00D2FF" /> <!-- Bright Turquoise -->
                <item android:offset="1.0" android:color="#00F5FF" /> <!-- Luminous Cyan -->
            </gradient>
        </aapt:attr>
    </path>
    
</vector>
